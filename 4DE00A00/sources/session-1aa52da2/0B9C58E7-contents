  ) +
  
  # Customize colors
  scale_fill_manual(
    values = c("steelblue4", "darkorange2")
  ) +
  
  # Label axes
  labs(
    title = "Effects of Experimental Treatment on Urchin Gonad Weight",
    x = "Experimental Treatment",
    y = "Urchin Gonad Weight (g)"
  ) +
  
  # Use non-default theme
  theme_classic() +
  
