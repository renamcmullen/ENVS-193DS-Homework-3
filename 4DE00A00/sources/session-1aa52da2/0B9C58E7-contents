```{r}
#| message: false
#| warning: false
# read in data
nests <- read_csv("nest_data_final.csv")

# clean and wrangle data
nests_clean <- nests %>%
  
  clean_names() %>%
  
  select(ant_species, height_cm, alive) %>%
  
  drop_na(ant_species, height_cm, alive) %>%
  
  mutate(
    
    # convert alive/dead to binary values
    alive = if_else(
      trimws(toupper(alive)) == "A",
      1,
      0
    ),
    
    # make species a factor
    ant_species = factor(
      ant_species,
      levels = c("RRB", "AB", "BBR")
    ),
    
    # full species names for plotting
    ant_species_full = case_when(
      ant_species == "RRB" ~ "Crematogaster sjostedti",
      ant_species == "AB" ~ "Crematogaster mimosae",
      ant_species == "BBR" ~ "Crematogaster nigriceps"
    )
  )

# fit selected model
model_1 <- glm(
  alive ~ height_cm + ant_species,
  data = nests_clean,
  family = binomial
)

# create sequence of heights for smooth predictions
height_seq <- seq(
  min(nests_clean$height_cm),
  max(nests_clean$height_cm),
  length.out = 100
)

# create prediction dataset
new_data <- expand.grid(
  height_cm = height_seq,
  ant_species = levels(nests_clean$ant_species)
)

# add full species names
new_data <- new_data %>%
  mutate(
    ant_species_full = case_when(
      ant_species == "RRB" ~ "Crematogaster sjostedti",
      ant_species == "AB" ~ "Crematogaster mimosae",
      ant_species == "BBR" ~ "Crematogaster nigriceps"
    )
  )

# generate predictions with standard errors
preds <- predict(
  model_1,
  newdata = new_data,
  type = "link",
  se.fit = TRUE
)

# calculate predicted probabilities and 95% confidence intervals
new_data <- new_data %>%
  mutate(
    fit_link = preds$fit,
    se = preds$se.fit,
    
    lower_link = fit_link - 1.96 * se,
    upper_link = fit_link + 1.96 * se,
    
    fit = plogis(fit_link),
    lower = plogis(lower_link),
    upper = plogis(upper_link)
  )

# create plot
ggplot() +
  
  # underlying data
  geom_jitter(
    data = nests_clean,
    aes(
      x = height_cm,
      y = alive,
      color = ant_species
    ),
    width = 5,
    height = 0.03,
    alpha = 0.5,
    size = 2
  ) +
  
  # confidence interval ribbon
  geom_ribbon(
    data = new_data,
    aes(
      x = height_cm,
      ymin = lower,
      ymax = upper
    ),
    fill = "skyblue",
    alpha = 0.3
  ) +
  
  # prediction line
  geom_line(
    data = new_data,
    aes(
      x = height_cm,
      y = fit
    ),
    color = "darkblue",
    linewidth = 1
  ) +
  
  # separate panels for each species
  facet_wrap(~ant_species_full) +
  
  # axis labels
  labs(
    x = "Tree height (cm)",
    y = "Predicted probability of nest occupancy"
  ) +
  
  # custom colors
  scale_color_manual(
    values = c(
      "#1b9e77",
      "#d95f02",
      "#7570b3"
    )
  ) +
  
  # clean theme
  theme_classic() +
  
  # remove legend
  theme(
    legend.position = "none"
  )
```

Figure 1: Probability of Survival Dependent on Nest Height of three different Ant Species. Logistic regression curves show the probability that a nest was alive across different tree heights. The orange points represents the Crematogaster mimosae, the majority of this species nests at 200cm with a 1.00 probability rate. The purple represents crematogaster nigriceps, they nest at around 200cm with a 1.00 probability. The green is crematogaster sjostedti, they have a wider range of nest height. Lujan, E., Nielsen, R., Short, Z., Wicks, S., Nderitu Watetu, W., Malingati Khasoha, L., Palmer, T. M., Goheen, J. R., & Alston, J. M. (2023)

